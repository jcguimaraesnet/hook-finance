{
  "platform": {
    "apiRuntime": "node:20"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/*.{png,svg,ico,webmanifest,js,css}"
    ]
  },
  "globalHeaders": {
    "Cache-Control": "no-cache"
  },
  "routes": [
    { "route": "/api/*", "allowedRoles": ["anonymous"] }
  ]
}
