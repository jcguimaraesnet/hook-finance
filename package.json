{
  "name": "hook-finance",
  "version": "0.1.0",
  "private": true,
  "description": "Webhook em Google Apps Script que grava POSTs em uma Google Sheet.",
  "scripts": {
    "login": "clasp login",
    "create": "clasp create --type standalone --title hook-finance --rootDir src",
    "push": "clasp push -f",
    "pull": "clasp pull",
    "deploy": "clasp deploy --description \"manual deploy\""
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^2.0.8"
  }
}
